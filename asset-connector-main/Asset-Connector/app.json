{
  "expo": {
    "name": "تريـاق",
    "slug": "smart-health-platform",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smarthealthplatform",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smarthealthplatform.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs location access to show nearby doctors and pharmacies.",
        "NSCameraUsageDescription": "This app needs camera access to scan medicine packaging.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to upload medicine photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00A896",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.smarthealthplatform.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00A896",
          "dark": {
            "backgroundColor": "#1A1D23"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5EDFFF",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "إشعارات ترياق"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby doctors and pharmacies."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "eas": {
        "projectId": "a79cd961-8176-447e-be5d-c1a53fd74000"
      }
    }
  }
}
