{
  "expo": {
    "name": "ترياق",
    "slug": "smart-health-platform",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smarthealthplatform",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smarthealthplatform.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs location access to show nearby doctors and pharmacies.",
        "NSCameraUsageDescription": "This app needs camera access to scan medicine packaging.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to upload medicine photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00A896",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.smarthealthplatform.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00A896",
          "dark": {
            "backgroundColor": "#1A1D23"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby doctors and pharmacies."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "updates": {
      "enabled": false
    }
  }
}
