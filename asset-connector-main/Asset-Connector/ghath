#!/bin/bash

PROJECT="/home/runner/workspace/asset-connector-main/Asset-Connector"
cd "$PROJECT"

echo "🧹 Killing old node processes..."
pkill -f tsx || true
pkill -f expo || true
pkill -f node || true

sleep 2

echo "🚀 Starting Server..."
PORT=5002 npm run server:dev &

sleep 3

echo "📱 Starting Expo (with QR)..."
npx expo start --tunnel --clear --port 8082
