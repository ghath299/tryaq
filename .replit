modules = ["nodejs-20"]

[nix]
channel = "stable-25_05"
packages = ["unzip", "nano", "psmisc"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

# 🔹 Workflow تشغيل التطبيق
[[workflows.workflow]]
name = "Start App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "REACT_NATIVE_PACKAGER_HOSTNAME=${REPLIT_DEV_DOMAIN:-localhost} npx expo start --web --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

# 🔹 Workflow البيلد (زر ثاني)
[[workflows.workflow]]
name = "Build APK"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo '🚀 Starting build...' && npm run build && echo '✅ Build finished! Check link above 👆'"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[userenv]

[userenv.shared]
EXPO_PUBLIC_API_BASE_URL = "https://d920424f-8dac-40e8-bc3f-ea3b97a7f63b-00-1c97s21p1hrgi.sisko.replit.dev"
EXPO_PUBLIC_DOMAIN = "d920424f-8dac-40e8-bc3f-ea3b97a7f63b-00-1c97s21p1hrgi.sisko.replit.dev"
